#!/bin/bash
# chezmoi:template:left-delimiter="{{" right-delimiter="}}"
set -euo pipefail

echo "Installing Homebrew packages..."

# Generate Brewfile and run bundle
brew bundle --file=- << 'EOF'
{{- range .brews }}
brew "{{ . }}"
{{- end }}
{{- range .casks }}
cask "{{ . }}"
{{- end }}
EOF

echo "Homebrew packages installed successfully."

# Install mise via curl
if ! command -v mise &>/dev/null; then
  echo "Installing mise..."
  curl https://mise.run | sh
  echo "mise installed successfully."
else
  echo "mise is already installed."
fi

# Activate mise and install all tools (ensures bun is available in this session)
if command -v mise &>/dev/null; then
  eval "$(mise activate bash)"
  mise install --yes
fi

# Install Claude Code via native installer
if ! command -v claude &>/dev/null; then
  echo "Installing Claude Code..."
  curl -fsSL https://claude.ai/install.sh | bash
  echo "Claude Code installed successfully."
else
  echo "Claude Code is already installed."
fi

# Install Codex CLI via bun
if command -v bun &>/dev/null; then
  echo "Installing Codex CLI..."
  bun add -g @openai/codex
  echo "Codex CLI installed successfully."
else
  echo "bun not found, skipping Codex CLI installation."
fi
